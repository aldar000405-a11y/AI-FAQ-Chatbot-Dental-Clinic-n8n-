      "id": "2c0d130a-6468-4ec2-b1cb-bfce1fe200c4",
      "name": "Send Executive Email",
      "webhookId": "99681941-42b1-47fb-9f78-29b676dfd2ea",
      "retryOnFail": true,
      "waitBetweenTries": 5000,
      "credentials": {
        "gmailOAuth2": {
          "id": "BfRvWx33K5n4cd9H",
          "name": "Email secert"
        }
