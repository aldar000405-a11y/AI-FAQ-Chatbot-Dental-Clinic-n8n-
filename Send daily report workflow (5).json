    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    COALESCE(SUM(\n        CASE\n            -- Shift the database timestamp to Dubai time before checking the date\n            WHEN (created_at AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Dubai')::DATE = (CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Dubai')::DATE\n            THEN total_tokens\n            ELSE 0\n        END\n    ),0) AS today_tokens,\n\n    COALESCE(SUM(total_tokens),0) AS total_tokens,\n\n    COALESCE(SUM(\n        CASE\n            -- Shift the database timestamp to Dubai time before checking the date\n            WHEN (created_at AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Dubai')::DATE = (CURRENT_TIMESTAMP AT TIME ZONE 'Asia/Dubai')::DATE\n            THEN cost_usd\n            ELSE 0\n        END\n    ),0) AS today_cost,\n\n    COALESCE(SUM(cost_usd),0) AS total_cost\n\nFROM user_token_usage;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
