        "jsCode": "// Helper to prevent [object Object] from appearing in text messages\nfunction safeString(val) {\n  if (!val) return \"Unknown\";\n  if (typeof val === 'object') {\n    try { return JSON.stringify(val); } \n    catch (e) { return \"Complex Object\"; }\n  }\n  return String(val);\n}\n\n// 1. Safely fetch data (prevents crashes if a node returns 0 items)\nconst Unanswered = $('Unanswered').all().filter(item => item.json?.question);\nconst ai_error = $('ai_errors').all().filter(item => item.json?.error_message);\nconst tokenStats = $('AI Token Stats').first()?.json || {}; // Added optional chaining\n\n// 2. Parse stats safely\nconst usedToday = Number(tokenStats.today_tokens || 0);\nconst usedTotal = Number(tokenStats.total_tokens || 0);\nconst todayCost = Number(tokenStats.today_cost || 0);\nconst totalCost = Number(tokenStats.total_cost || 0);\n\nconst today = new Date();\nconst formatDate = today.toLocaleDateString('en-US', {\n  timeZone: 'Asia/Dubai',\n  month: 'long',\n  day: 'numeric',\n  year: 'numeric'\n});\n\nlet message = `Daily FAQ Bot Digest - ${formatDate}\\n\\n`;\n\nconst unansweredCount = Unanswered.length;\nconst errorCount = ai_error.length;\n\nconst medicalRisk = [];\nconst otherQuestions = [];\n\nfor (const item of Unanswered) {\n  if (item.json.reason?.toLowerCase() === \"medical_risk\") {\n    medicalRisk.push(item);\n  } else {\n    otherQuestions.push(item);\n  }\n}\n\n// 3. Build the plain text message\nif (unansweredCount === 0 && errorCount === 0) {\n  message += \"No unanswered questions or system errors in the last 24 hours.\";\n} else {\n\n  // ===== Unanswered Questions =====\n  if (medicalRisk.length > 0) {\n    message += `MEDICAL RISK ESCALATIONS: ${medicalRisk.length}\\n`;\n    for (const item of medicalRisk) {\n      message += `• \"${safeString(item.json.question)}\" (${safeString(item.json.session_id)})\\n`;\n    }\n    message += \"\\n\";\n  }\n\n  if (otherQuestions.length > 0) {\n    message += `Unanswered Questions: ${otherQuestions.length}\\n`;\n    const preview = otherQuestions.slice(0, 5);\n\n    for (const item of preview) {\n      message += `• ${safeString(item.json.reason)}: \"${safeString(item.json.question)}\" (${safeString(item.json.session_id)})\\n`;\n    }\n\n    if (otherQuestions.length > 5) {\n      message += `... and ${otherQuestions.length - 5} more unanswered questions.\\n`;\n    }\n    message += \"\\n\";\n  }\n\n  // ===== AI Errors =====\n  if (errorCount > 0) {\n    message += `AI System Errors: ${errorCount}\\n`;\n\n    // Count identical error messages safely\n    const groupedErrors = {};\n    for (const item of ai_error) {\n      const errorStr = safeString(item.json.error_message);\n      groupedErrors[errorStr] = (groupedErrors[errorStr] || 0) + 1;\n    }\n\n    for (const [error, count] of Object.entries(groupedErrors)) {\n      message += `• ${error} × ${count}\\n`;\n    }\n    message += \"\\n\";\n  }\n  \n  // ===== AI Token Usage =====\n  message += `AI Token Usage\\n`;\n  message += `• Used today: ${usedToday.toLocaleString()} tokens\\n`;\n  message += `• Used total: ${usedTotal.toLocaleString()} tokens\\n`;\n  message += `• Today's cost: $${todayCost.toFixed(4)}\\n`;\n  message += `• Total cost: $${totalCost.toFixed(4)}\\n\\n`;\n\n  message += `Total escalations: ${unansweredCount} | System errors: ${errorCount}`;\n}\n\nreturn [\n  {\n    json: {\n      message\n    }\n  }\n];"
      },
